# ~/.config/mako/config
# Tema Nord para Mako

# Ejemplo: Un fondo oscuro con aproximadamente un 80% de opacidad (CC)
background-color=#1e1e2eCC
text-color=#D8DEE9
border-color=#88C0D0
progress-color=over #434C5E

font=monospace 10
width=300
height=100
margin=10
padding=15
border-size=2
border-radius=5
default-timeout=5000
format=<b>%s</b>\n%b

[urgency=high]
border-color=#BF616A
default-timeout=0
